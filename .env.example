# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Free from huduser.gov/portal/datasets/fmr-api.html
# Enables: HUD Fair Market Rents + Income Limits per ZIP
HUD_API_TOKEN=

# Free from api.census.gov/data/key_signup.html
# Optional — DEMO_KEY is used if unset (rate-limited)
CENSUS_API_KEY=

# Free tier: 50 calls/month — rentcast.io
# Enables: actual nearby rental listings per property
RENTCAST_API_KEY=
